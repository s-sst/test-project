# =============================================================================
# AI Governance & Compliance Platform — environment configuration template.
# Copy to `.env` and fill in. NEVER commit a real .env (see .gitignore).
# All secrets are read from the environment; none are hard-coded in source.
# =============================================================================

# --- Core Django ---
# Which settings module to load: config.settings.dev | config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
# Comma-separated. Required in production.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Leave DATABASE_URL empty to use the bundled SQLite (dev default).
# For PostgreSQL: postgres://user:pass@host:5432/dbname
DATABASE_URL=

# --- CORS (frontend origins, comma-separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- File uploads / security ---
# Max upload size in megabytes.
MAX_UPLOAD_SIZE_MB=50
# Comma-separated list of accepted extensions.
ALLOWED_UPLOAD_EXTENSIONS=pdf,docx,png,jpg,jpeg,tiff

# --- Framework configuration engine ---
# Directory holding the JSON/YAML control libraries.
FRAMEWORKS_DATA_DIR=frameworks_data

# --- LLM provider (Phase 3, provider-agnostic; unused in Phase 1) ---
# LLM_PROVIDER=anthropic         # anthropic | openai | gemini | ollama
# LLM_MODEL=claude-opus-4-8
# LLM_API_KEY=
# LLM_BASE_URL=                  # for self-hosted / Ollama
# LLM_TEMPERATURE=0.0            # deterministic by default
# LLM_SEED=42

# --- Vector store (Phase 2) ---
# CHROMA_PERSIST_DIR=.chroma
# EMBEDDING_MODEL=nomic-embed-text
